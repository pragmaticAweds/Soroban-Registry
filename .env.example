# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_DB=soroban_registry

# API
#
# DATABASE_URL is required by the backend at BOTH compile time and runtime.
# SQLx's `query!` / `query_as!` / `query_scalar!` macros connect to this
# database during `cargo build` to verify SQL against the live schema, so
# the database must exist AND have all migrations applied before building.
#
# If you cannot reach a database at build time (e.g. some CI runners),
# set SQLX_OFFLINE=true and commit `backend/.sqlx/` generated by
# `cargo sqlx prepare`. See README "Running From Source" for details.
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/soroban_registry
# SQLX_OFFLINE=true
RUST_LOG=info
JWT_SECRET=changeme_use_at_least_32_chars_of_random_data
PORT=3001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# CORS — comma-separated list of allowed browser origins (scheme + host + port,
# no trailing slash, no path). Each entry must match a Request Origin exactly.
# Example: ALLOWED_ORIGINS=http://localhost:3000,https://soroban-registry.vercel.app
# If unset, defaults to: http://localhost:3000,https://soroban-registry.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# AI-Powered Contract Assistant (Issue #643)
# Provider: openai or anthropic
AI_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key
# Or for Anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_MODEL=gpt-4-turbo-preview
# Anthropic model: claude-3-opus-20240229, claude-3-sonnet-20240229
ANTHROPIC_MODEL=claude-3-opus-20240229
AI_TIMEOUT=60
AI_MAX_RETRIES=3
AI_BASE_URL=

# Real-Time Contract State Monitor (Issue #647) - Polling interval (seconds)
STATE_POLL_INTERVAL=5

# Already existing variables...

# Alertmanager (optional)
# SLACK_WEBHOOK_URL=
# PAGERDUTY_SERVICE_KEY=

# DB pool tuning (optional, auto-sized by default)
# DB_MAX_POOL_SIZE=20
