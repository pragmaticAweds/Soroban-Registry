# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_DB=soroban_registry

# API
#
# DATABASE_URL is required by the backend at BOTH compile time and runtime.
# SQLx's `query!` / `query_as!` / `query_scalar!` macros connect to this
# database during `cargo build` to verify SQL against the live schema, so
# the database must exist AND have all migrations applied before building.
#
# If you cannot reach a database at build time (e.g. some CI runners),
# set SQLX_OFFLINE=true and commit `backend/.sqlx/` generated by
# `cargo sqlx prepare`. See README "Running From Source" for details.
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/soroban_registry
# SQLX_OFFLINE=true
RUST_LOG=info
JWT_SECRET=changeme_use_at_least_32_chars_of_random_data
PORT=3001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# CORS — comma-separated list of allowed browser origins (scheme + host + port,
# no trailing slash, no path). Each entry must match a Request Origin exactly.
# Example: ALLOWED_ORIGINS=http://localhost:3000,https://soroban-registry.vercel.app
# If unset, defaults to: http://localhost:3000,https://soroban-registry.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# AI-Powered Contract Assistant (Issue #643)
# Provider: openai or anthropic
AI_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key
# Or for Anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_MODEL=gpt-4-turbo-preview
# Anthropic model: claude-3-opus-20240229, claude-3-sonnet-20240229
ANTHROPIC_MODEL=claude-3-opus-20240229
AI_TIMEOUT=60
AI_MAX_RETRIES=3
AI_BASE_URL=

# Real-Time Contract State Monitor (Issue #647) - Polling interval (seconds)
STATE_POLL_INTERVAL=5

# Marketplace — license signing key (Phase 1)
#
# Ed25519 32-byte seed, base64-encoded. Generate with:
#   openssl rand -base64 32
# All marketplace license issuance/validation endpoints return 503 until
# this is set. Rotating the value invalidates every issued license token,
# so treat it like a long-lived secret.
MARKETPLACE_LICENSE_SIGNING_KEY=

# Marketplace — Stripe (Phase 2)
#
# Use sk_test_… for development; sk_live_… for production. The same
# code path handles both — there is no live-mode guard, so be careful
# which key you ship to which environment.
#   * SECRET_KEY  — server-to-Stripe API auth (Bearer / Basic auth)
#   * WEBHOOK_SECRET — whsec_… string from the Stripe dashboard,
#     used to HMAC-verify incoming webhook events.
# Checkout + webhook endpoints return 503 until both are set.
MARKETPLACE_STRIPE_SECRET_KEY=
MARKETPLACE_STRIPE_WEBHOOK_SECRET=

# Marketplace — USDC on Stellar (Phase 3)
#
# Single-platform-wallet model: all USDC payments go to one receiving
# address. Per-publisher wallets are out of scope for v1.
#   * RECEIVING_ADDRESS — Stellar account that holds platform USDC.
#     Must be a 56-char StrKey starting with 'G'.
#   * ASSET_ISSUER — USDC issuer for the target network. On Stellar
#     public network this is Circle's issuer
#     (GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN).
#     Test networks use a different issuer; check Circle docs.
#   * NETWORK — 'testnet' or 'public'. Defaults to 'testnet'.
# Intent + confirm endpoints return 503 until RECEIVING_ADDRESS and
# ASSET_ISSUER are set.
MARKETPLACE_USDC_RECEIVING_ADDRESS=
MARKETPLACE_USDC_ASSET_ISSUER=
MARKETPLACE_USDC_NETWORK=testnet

# Marketplace — USDC indexer scanner (Phase 3, indexer crate)
#
# The indexer's USDC scanner polls Horizon for payments to
# MARKETPLACE_USDC_RECEIVING_ADDRESS and POSTs each match to
# /api/marketplace/usdc/confirm. The scanner is opt-in — it only
# starts when the receiving address above is set.
#   * HORIZON_URL — Stellar Horizon endpoint (auto-defaulted from
#     NETWORK if unset).
#   * REGISTRY_BASE_URL — base URL the indexer uses to reach the API
#     (e.g. http://localhost:3001 in dev, internal service URL in
#     prod). Must NOT include a trailing slash.
#   * INDEXER_API_TOKEN — bearer token the scanner sends to the
#     confirm endpoint. Must be a valid JWT issued by the same
#     auth path as regular publishers; the publisher identified by
#     the token will be recorded in license metadata as
#     "confirmed_by". Issuing/rotating this token is an operator
#     task — there's no auto-mint.
MARKETPLACE_HORIZON_URL=
MARKETPLACE_REGISTRY_BASE_URL=http://localhost:3001
MARKETPLACE_INDEXER_API_TOKEN=

# Already existing variables...

# Alertmanager (optional)
# SLACK_WEBHOOK_URL=
# PAGERDUTY_SERVICE_KEY=

# DB pool tuning (optional, auto-sized by default)
# DB_MAX_POOL_SIZE=20
