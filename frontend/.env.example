# ─── Soroban Registry Frontend ── .env.example ───────────────────────────────
#
# Copy this file to .env.local and fill in your values.
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser.

# ── Backend API (required for local backend) ──────────────────────────────────
# Set this to your deployed backend URL (e.g., http://localhost:3001 for local dev).
# If empty, the frontend uses relative paths (/api/*) for same-domain deployment.
NEXT_PUBLIC_API_URL=

# ── Mock data (development only) ─────────────────────────────────────────────
# Set to "true" to use local mock data instead of live APIs.
# NEVER set this in production.
NEXT_PUBLIC_USE_MOCKS=false

# ── Stellar network (mainnet | testnet | futurenet) ───────────────────────────
# Controls which Stellar network the live data adapters query.
NEXT_PUBLIC_STELLAR_NETWORK=mainnet

# ── Activity feed poll interval (milliseconds) ───────────────────────────────
# How often the activity feed and recent contracts refresh from Stellar.
# Default: 30000 (30 seconds). Set lower for faster updates (min recommended: 10000).
NEXT_PUBLIC_ACTIVITY_POLL_MS=30000
